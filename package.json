{
  "name": "opencode-huge-agents",
  "version": "0.1.0",
  "description": "OpenCode multi-agent plugin with refactor (review-first), ask (read-only advisor), and exec (smart executor) agents",
  "type": "module",
  "bin": {
    "opencode-huge-agents": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "bun test",
    "postinstall": "node -e \"console.log('opencode-huge-agents installed with 3 agents: refactor, ask, exec'); console.log('To continue setup, run: npx opencode-huge-agents install'); console.log('With Bun: bunx opencode-huge-agents install');\"",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opencode",
    "plugin",
    "agents",
    "refactor",
    "ask",
    "exec"
  ],
  "license": "MIT",
  "author": "yurirxmos",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yurirxmos/opencode-huge-agents.git"
  },
  "bugs": {
    "url": "https://github.com/yurirxmos/opencode-huge-agents/issues"
  },
  "homepage": "https://github.com/yurirxmos/opencode-huge-agents#readme",
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.1.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.2.10",
    "@types/node": "^24.3.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1",
    "opencode-huge-agents": "^0.1.0"
  }
}
